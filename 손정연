<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>손정연 | 러블리 캣 포트폴리오</title>
    <style>
        /* ==========================================
           1. DESIGN SYSTEM & RESET (파스텔톤 디자인 시스템)
           ========================================== */
        :root {
            --bg-main: #faf8f5;          /* 부드러운 우유빛 아이보리 배경 */
            --bg-card: rgba(255, 255, 255, 0.75); /* 글래스모피즘 투명 카드 */
            --border-card: rgba(255, 255, 255, 0.6);
            
            /* 핑크 & 민트 파스텔톤 시스템 */
            --color-pink: #ffcad4;       /* 달콤한 파스텔 핑크 */
            --color-mint: #b7e4c7;       /* 싱그러운 파스텔 민트 */
            --color-accent: #98f5e1;     /* 하이라이트 민트 */
            
            --text-main: #4a4a4a;        /* 부드러운 다크 그레이 */
            --text-sub: #7a7a7a;         /* 설명용 그레이 */
            --font-sans: 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif;
            --transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* 통통 튀는 애니메이션 효과 */
            --shadow: 0 10px 30px rgba(255, 202, 212, 0.25);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
            font-family: var(--font-sans);
            background-color: var(--bg-main);
            color: var(--text-main);
            overflow-x: hidden;
        }

        body {
            line-height: 1.6;
            position: relative;
        }

        /* 스크롤바 커스텀 */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-main);
        }
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, var(--color-pink), var(--color-mint));
            border-radius: 4px;
        }

        /* ==========================================
           2. CAT BACKGROUNDS (배경에 떠다니는 고양이들)
           ========================================== */
        .cat-bg {
            position: fixed;
            font-size: 2.5rem;
            user-select: none;
            pointer-events: none;
            z-index: -1;
            opacity: 0.25;
            animation: floatCat 6s infinite alternate ease-in-out;
        }
        
        /* 고양이들 각각의 위치와 애니메이션 속도 설정 */
        .cat1 { top: 15%; left: 8%; animation-delay: 0s; }
        .cat2 { top: 40%; right: 10%; animation-delay: 1.5s; font-size: 3rem; }
        .cat3 { bottom: 20%; left: 12%; animation-delay: 3s; }
        .cat4 { bottom: 45%; left: 85%; animation-delay: 0.5s; }
        .cat5 { top: 75%; right: 45%; animation-delay: 2s; }

        @keyframes floatCat {
            0% { transform: translateY(0) rotate(0deg); }
            100% { transform: translateY(-20px) rotate(10deg); }
        }

        /* 은은한 파스텔 빛 그라데이션 오너먼트 */
        .bg-glow {
            position: fixed;
            top: 25%;
            left: 25%;
            width: 50vw;
            height: 50vw;
            background: radial-gradient(circle, rgba(255, 202, 212, 0.4) 0%, rgba(183, 228, 199, 0.3) 50%, rgba(0,0,0,0) 70%);
            pointer-events: none;
            z-index: -2;
            filter: blur(60px);
        }

        /* ==========================================
           3. LAYOUT & NAVIGATION (네비게이션)
           ========================================== */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-card);
            background: rgba(255, 255, 255, 0.4);
        }

        .nav-logo {
            font-size: 1.3rem;
            font-weight: 800;
            letter-spacing: 1px;
            color: #5c5c5c;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .nav-logo span {
            color: #ff9ebb;
        }

        .nav-menu {
            display: flex;
            gap: 30px;
            list-style: none;
        }

        .nav-item a {
            color: var(--text-sub);
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 600;
            transition: var(--transition);
        }

        .nav-item a:hover, .nav-item.active a {
            color: #ff8fa3;
            transform: scale(1.05);
        }

        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 24px;
        }

        section {
            padding: 140px 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .section-header {
            margin-bottom: 50px;
            text-align: center;
        }

        .section-tag {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #ff8fa3;
            margin-bottom: 8px;
            display: block;
            font-weight: 700;
        }

        .section-title {
            font-size: 2.3rem;
            font-weight: 800;
            color: #4a4a4a;
        }

        /* ==========================================
           4. HERO SECTION (첫 화면)
           ========================================== */
        #hero {
            height: 100vh;
            position: relative;
        }

        .hero-wrapper {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            width: 100%;
        }

        .hero-cat-icon {
            font-size: 4rem;
            margin-bottom: 15px;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .hero-sub {
            font-size: 1.2rem;
            color: #83c5be;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .hero-title {
            font-size: 4rem;
            font-weight: 900;
            line-height: 1.2;
            margin-bottom: 25px;
            color: #4a4a4a;
        }

        .hero-title span.gradient-text {
            background: linear-gradient(135deg, #ff8fa3 0%, #b7e4c7 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .typing-container {
            font-size: 1.5rem;
            color: var(--text-sub);
            height: 35px;
            margin-bottom: 40px;
        }

        #typing-text {
            border-right: 3px solid var(--color-pink);
            padding-right: 5px;
            font-weight: 600;
            color: #6c757d;
        }

        .cta-btn {
            display: inline-flex;
            align-items: center;
            padding: 15px 35px;
            background: linear-gradient(135deg, var(--color-pink), #ffb3c1);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 700;
            font-size: 1rem;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .cta-btn:hover {
            transform: translateY(-4px) scale(1.03);
            box-shadow: 0 15px 35px rgba(255, 202, 212, 0.4);
        }

        /* ==========================================
           5. ABOUT ME SECTION (프로필 정보)
           ========================================== */
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 40px;
            align-items: center;
        }

        .profile-main-card {
            background: var(--bg-card);
            border: 2px solid var(--border-card);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 45px 35px;
            text-align: center;
            box-shadow: var(--shadow);
            position: relative;
        }

        .profile-avatar {
            width: 110px;
            height: 110px;
            background: linear-gradient(135deg, #ffe5ec, #ffcad4);
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 3rem;
            box-shadow: inset 0 4px 10px rgba(0,0,0,0.05);
        }

        .profile-name {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 6px;
            color: #4a4a4a;
        }

        .profile-job {
            font-size: 0.95rem;
            color: #ff8fa3;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .profile-quote {
            font-size: 1rem;
            color: var(--text-sub);
            font-weight: 500;
        }

        .about-details-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .detail-card {
            background: var(--bg-card);
            border: 2px solid var(--border-card);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 22px;
            padding: 25px;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .detail-card:hover {
            transform: translateY(-5px);
            border-color: var(--color-pink);
            background: white;
        }

        .detail-icon {
            font-size: 1.8rem;
            margin-bottom: 12px;
            display: inline-block;
        }

        .detail-label {
            font-size: 0.85rem;
            color: #a3b18a;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .detail-value {
            font-size: 1.15rem;
            font-weight: 700;
            color: #555;
        }

        /* ==========================================
           6. MY SKILLS SECTION (역량 진행바)
           ========================================== */
        .skills-container {
            max-width: 750px;
            margin: 0 auto;
            width: 100%;
            background: var(--bg-card);
            border: 2px solid var(--border-card);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 30px;
            padding: 45px;
            box-shadow: var(--shadow);
        }

        .skill-item {
            margin-bottom: 30px;
        }

        .skill-item:last-child {
            margin-bottom: 0;
        }

        .skill-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .skill-name {
            font-size: 1.1rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .skill-percentage {
            font-size: 1rem;
            font-weight: 700;
            color: #ff8fa3;
        }

        .skill-bar-bg {
            width: 100%;
            height: 12px;
            background: rgba(0, 0, 0, 0.04);
            border-radius: 50px;
            overflow: hidden;
        }

        .skill-bar-fill {
            height: 100%;
            width: 0%; /* JS 애니메이션 구동 */
            background: linear-gradient(to right, var(--color-pink), var(--color-mint));
            border-radius: 50px;
            transition: width 1.5s cubic-bezier(0.1, 1, 0.1, 1);
        }

        .skill-desc {
            font-size: 0.85rem;
            color: var(--text-sub);
            margin-top: 8px;
            padding-left: 4px;
        }

        /* ==========================================
           7. MY FAVORITES SECTION (취향 카드)
           ========================================== */
        .fav-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }

        .fav-card {
            background: var(--bg-card);
            border: 2px solid var(--border-card);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 26px;
            padding: 35px;
            display: flex;
            gap: 20px;
            align-items: center;
            transition: var(--transition);
            box-shadow: var(--shadow);
        }

        .fav-card:hover {
            transform: scale(1.03) translateY(-3px);
            border-color: var(--color-mint);
            background: white;
        }

        .fav-icon-box {
            width: 65px;
            height: 65px;
            background: #f0fdf4;
            border-radius: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 2rem;
            flex-shrink: 0;
            border: 1px solid rgba(183, 228, 199, 0.4);
        }

        .fav-content h3 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 6px;
            color: #4a4a4a;
        }

        .fav-content p {
            font-size: 0.9rem;
            color: var(--text-sub);
        }

        .fav-artist-badge {
            display: inline-block;
            margin-top: 8px;
            padding: 4px 14px;
            background: #ffe5ec;
            border: 1px solid #ffcad4;
            color: #ff758f;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 700;
        }

        /* ==========================================
           8. MY DREAM SECTION (미래 목표 타임라인)
           ========================================== */
        .dream-timeline {
            position: relative;
            max-width: 750px;
            margin: 0 auto;
        }

        .dream-timeline::before {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 50%;
            width: 3px;
            background: linear-gradient(to bottom, var(--color-pink), var(--color-mint));
            transform: translateX(-50%);
        }

        .dream-node {
            position: relative;
            margin-bottom: 50px;
            width: 100%;
            display: flex;
        }

        .dream-node:last-child {
            margin-bottom: 0;
        }

        .dream-node:nth-child(odd) { justify-content: flex-start; }
        .dream-node:nth-child(even) { justify-content: flex-end; }

        .dream-pointer {
            position: absolute;
            left: 50%;
            top: 25px;
            width: 18px;
            height: 18px;
            background: white;
            border: 4px solid var(--color-pink);
            border-radius: 50%;
            transform: translateX(-50%);
            z-index: 10;
        }

        .dream-node:nth-child(even) .dream-pointer {
            border-color: var(--color-mint);
        }

        .dream-box {
            width: 44%;
            background: var(--bg-card);
            border: 2px solid var(--border-card);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-radius: 24px;
            padding: 30px;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        .dream-box:hover {
            transform: translateY(-5px);
            background: white;
            border-color: #ffcad4;
        }

        .dream-box h3 {
            font-size: 1.2rem;
            font-weight: 800;
            margin-bottom: 10px;
            color: #4a4a4a;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .dream-box p {
            font-size: 0.9rem;
            color: var(--text-sub);
        }

        /* ==========================================
           9. FOOTER (하단 레이아웃)
           ========================================== */
        footer {
            border-top: 1px solid var(--border-card);
            padding: 35px 0;
            text-align: center;
            color: var(--text-sub);
            font-size: 0.85rem;
            background: rgba(255,255,255,0.3);
        }

        /* 스크롤 감지 트랜지션 효과 */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* ==========================================
           10. RESPONSIVE DESIGN (모바일 반응형)
           ========================================== */
        @media (max-width: 968px) {
            .hero-title { font-size: 3rem; }
            .about-grid { grid-template-columns: 1fr; }
            .fav-grid { grid-template-columns: 1fr; }
            .dream-timeline::before { left: 20px; }
            .dream-node { justify-content: flex-end !important; }
            .dream-box { width: calc(100% - 50px); }
            .dream-pointer { left: 20px; transform: translateX(-50%); }
        }

        @media (max-width: 576px) {
            .navbar { padding: 15px 20px; }
            .nav-menu { gap: 15px; }
            .nav-item a { font-size: 0.85rem; }
            .hero-title { font-size: 2.2rem; }
            .typing-container { font-size: 1.1rem; }
            .section-title { font-size: 1.8rem; }
            .about-details-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
